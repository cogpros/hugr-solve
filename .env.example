# hugr-solve -- API Keys
# Copy this file to .env and fill in your keys.
# This file is in .gitignore and should never be committed.

# Agent A API key (default: the "opening" agent)
AGENT_A_API_KEY=your-api-key-here

# Agent B API key (default: the "challenging" agent)
AGENT_B_API_KEY=your-api-key-here

# Seedvault token (optional, for shared memory search)
# Get Seedvault at https://github.com/pashpashpash/vault-ai or similar
SEEDVAULT_TOKEN=

# Telegram notifications (if NOTIFY_METHOD=telegram in config.sh)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Discord notifications (if NOTIFY_METHOD=discord in config.sh)
DISCORD_WEBHOOK_URL=
